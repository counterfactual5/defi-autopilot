# .env template — copy to .env and fill in your values

# RPC endpoints (defaults are provided; override here for better reliability)
RPC_BASE=https://mainnet.base.org
RPC_ETHEREUM=https://eth.llamarpc.com
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_OPTIMISM=https://mainnet.optimism.io
RPC_POLYGON=https://polygon-rpc.com

# Signer private key (NEVER commit to git)
SIGNER_PRIVATE_KEY=

# Optional: 1inch API key (free tier works without it)
INCH_API_KEY=
